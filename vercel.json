{
    "version": 2,
    "buildCommand": "echo 'Build complete'",
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/index.js"
        }
    ],
    "env": {
        "NODE_ENV": "production"
    }
}
